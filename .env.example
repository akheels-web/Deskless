# Copy to .env and fill in. docker-compose reads .env automatically.

# --- required in production ---
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=helpdesk.example.com,localhost
CSRF_TRUSTED_ORIGINS=https://helpdesk.example.com
DB_PASSWORD=change-me

# --- branding (per client) ---
BRAND_NAME=Deskless
BRAND_COLOR=#1f2937
BRAND_ACCENT=#2563eb

# --- outbound email (SMTP). Leave EMAIL_HOST blank to print to console. ---
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=support@example.com

# --- email-to-ticket intake (IMAP). Blank disables it. ---
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=

# --- optional AI triage ---
OPENAI_API_KEY=
